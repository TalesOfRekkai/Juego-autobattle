# ============================================
# DOJO / STARKNET CONFIGURATION
# ============================================
# Copy this file to .env and fill in the values.

# World contract address (from sozo migrate output)
VITE_WORLD_ADDRESS=0x0

# Torii indexer URL
VITE_TORII_URL=http://localhost:8080

# Katana/Starknet RPC URL
VITE_RPC_URL=http://localhost:5050

# Enable Cartridge Controller for authentication (true for Slot/production)
VITE_USE_CONTROLLER=false
